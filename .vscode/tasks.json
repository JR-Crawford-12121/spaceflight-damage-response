{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run pipeline: python main.py",
      "type": "shell",
      "command": "python main.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Download OSD data from Torchlight notebook",
      "type": "shell",
      "command": "python main.py --download-from-notebook",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run pipeline: full setup (venv, pip, main)",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File scripts/run_pipeline.ps1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
